# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env in the ROOT directory
# and fill in your values

# MongoDB Connection String
# For local development:
# MONGO_URI=mongodb://127.0.0.1:27017/institute-management

# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/institute-management?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# JWT Secret Key (use a long random string for production)
# Generate one at: https://randomkeygen.com/
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port (usually set automatically by hosting platform)
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS - set this in production)
# FRONTEND_URL=https://your-frontend-domain.vercel.app
